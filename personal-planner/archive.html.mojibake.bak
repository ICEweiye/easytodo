п»ҝ<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>иӨ°жҺ“гҖӮ - ж¶“оҒғжұүз‘ҷеӢ«еһқз» пј„жӮҠ</title>
    <link rel="stylesheet" href="style.css">
    <script src="storage-sync.js"></script>
</head>
<body>
    <div class="app-layout">
        <!-- е®ёпёҝжҷ¶зҖөиү°еҹ…йҸҚ?-->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo">йҲј?/div>
            </div>
            <nav class="sidebar-nav">
                <a href="index.html" class="nav-item">
                    <span class="nav-text">ж¶“е©ҡгҖү</span>
                </a>
                <a href="life.html" class="nav-item">
                    <span class="nav-text">йҗўзҶёжӨҝ</span>
                </a>
                <a href="stats.html" class="nav-item">
                    <span class="nav-text">зјҒзҶ»о…ё</span>
                </a>
                <a href="review.html" class="nav-item">
                    <span class="nav-text">жҫ¶е¶ҮжҙҸ</span>
                </a>
                <a href="archive.html" class="nav-item active">
                    <span class="nav-text">иӨ°жҺ“гҖӮ</span>
                </a>
            </nav>
            <div class="sidebar-footer">
                <button class="collapse-btn" id="collapseBtn" onclick="toggleSidebar()">
                    <svg class="collapse-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                </button>
            </div>
        </aside>

        <!-- ж¶“иҜІе”ҙзҖ№з‘°е°Ҝ -->
        <main class="main-content">
            <div class="container">
                <header class="header">
                    <div class="header-content">
                        <h1 class="space-name">иӨ°жҺ“гҖӮ</h1>
                        <span class="current-date" id="currentDate"></span>
                    </div>
                </header>

                <!-- йҸҚеӣ©о„·жӨӨйқӣоҮұй‘ё?-->
                <div class="tabs">
                    <button class="tab-btn active" data-tab="projects" onclick="switchTab('projects')">жӨӨеңӯжҙ°</button>
                    <button class="tab-btn" data-tab="okrs" onclick="switchTab('okrs')">йҗ©оҶҪзҲЈ</button>
                    <button class="tab-btn" data-tab="books" onclick="switchTab('books')">ж¶”пёҫзқ„</button>
                </div>

                <!-- йҸҚеӣ©о„·жӨӨйқӣе”ҙзҖ№?-->
                <div class="tab-content">
                    <div class="tab-panel active" id="tab-projects">
                        <div class="module-header">
                            <h2 class="module-title">е®ёжҸ’з•¬йҺҙж„°гҖҚйҗ©?/h2>
                        </div>
                        <div class="archive-list" id="completedProjects">
                            <div class="empty-state">йҸҶеӮӣжЈӨе®ёжҸ’з•¬йҺҙж„°гҖҚйҗ©?/div>
                        </div>
                    </div>

                    <div class="tab-panel" id="tab-okrs">
                        <div class="module-header">
                            <h2 class="module-title">е®ёжҸ’з•¬йҺҙж„®жҙ°йҸҚ?/h2>
                        </div>
                        <div class="archive-list" id="completedOkrs">
                            <div class="empty-state">йҸҶеӮӣжЈӨе®ёжҸ’з•¬йҺҙж„®жҙ°йҸҚ?/div>
                        </div>
                    </div>

                    <div class="tab-panel" id="tab-books">
                        <div class="module-header">
                            <h2 class="module-title">е®ёиҢ¶оҮ°ж¶”пёҫзқ„</h2>
                        </div>
                        <div class="archive-list" id="completedBooks">
                            <div class="empty-state">йҸҶеӮӣжЈӨе®ёиҢ¶оҮ°ж¶”пёҫзқ„</div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        // йҸҮеӯҳжҹҠйҸғгғҰж№Ў
        function updateDate() {
            const now = new Date();
            const options = { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' };
            document.getElementById('currentDate').textContent = now.toLocaleDateString('zh-CN', options);
        }

        // йҚ”зҠәжөҮиӨ°жҺ“гҖӮйҸҒзүҲеөҒ
        function loadArchive() {
            const projects = JSON.parse(localStorage.getItem('planner_projects') || '[]');
            const okrs = JSON.parse(localStorage.getItem('planner_okrs') || '[]');
            const books = JSON.parse(localStorage.getItem('planner_books') || '[]');

            // е®ёжҸ’з•¬йҺҙж„°гҖҚйҗ©оҮҶзҙҷжқ©ж¶ҳе®і100%йҺҙж §еҮЎжқ©еӣЁж№Ўй”ӣ?            const completedProjects = projects.filter(p => p.progress >= 100);
            if (completedProjects.length > 0) {
                document.getElementById('completedProjects').innerHTML = completedProjects.map(p => `
                    <div class="archive-item">
                        <div class="archive-icon" style="background: var(--gradient-brown);">йүҒ?/div>
                        <div class="archive-content">
                            <div class="archive-title">${p.name}</div>
                            <div class="archive-meta">${formatDate(p.start)} - ${formatDate(p.end)} и·Ҝ е®ёжҸ’з•¬йҺҙ?/div>
                        </div>
                        <div class="archive-badge">100%</div>
                    </div>
                `).join('');
            }

            // е®ёжҸ’з•¬йҺҙ?OKRй”ӣе ҹеўҚйҸҲ?KR й–®и—үз•¬йҺҙж„¶зҙҡ
            const completedOkrs = okrs.filter(o => o.krs.length > 0 && o.krs.every(kr => kr.completed));
            if (completedOkrs.length > 0) {
                document.getElementById('completedOkrs').innerHTML = completedOkrs.map(o => `
                    <div class="archive-item">
                        <div class="archive-icon" style="background: var(--gradient-sage);">йүҒ?/div>
                        <div class="archive-content">
                            <div class="archive-title">${o.title}</div>
                            <div class="archive-meta">${o.period} и·Ҝ ${o.krs.length} ж¶“оҒ„еҸ§й–ҝоҶҫзІЁйҸӢж»ғеҸҸй–®г„Ҙз•¬йҺҙ?/div>
                        </div>
                        <div class="archive-badge">100%</div>
                    </div>
                `).join('');
            }

            // е®ёиҢ¶оҮ°ж¶”пёҫзқ„
            const completedBooks = books.filter(b => b.current >= b.total);
            if (completedBooks.length > 0) {
                document.getElementById('completedBooks').innerHTML = completedBooks.map(b => `
                    <div class="archive-item">
                        <div class="archive-icon" style="background: var(--gradient-apricot);">йүҒ?/div>
                        <div class="archive-content">
                            <div class="archive-title">${b.title}</div>
                            <div class="archive-meta">${b.author || 'йҸҲоҒҶз…ЎжөЈж»ҶвӮ¬?} и·Ҝ ${b.total} жӨӨ?/div>
                        </div>
                        <div class="archive-badge">е®ёиҢ¶оҮ°</div>
                    </div>
                `).join('');
            }
        }

        function formatDate(dateStr) {
            const date = new Date(dateStr);
            return `${date.getMonth() + 1}йҸҲ?{date.getDate()}йҸғоҷҰ;
        }

        // йҚ’жҝҶоқҗйҚ–?        document.addEventListener('DOMContentLoaded', () => {
            updateDate();
            loadArchive();
        });

        // жёҡСҶз«ҹйҸҚеҝ”е§ҢйҚҷзҠІе§ӣй‘і?        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('collapsed');
            localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
        }

        // жӨӨз”ёжҪ°йҚ”зҠәжөҮйҸғиҲөд»®жҫ¶е¶Үе§ёйҺ¬?        const sidebar = document.getElementById('sidebar');
        const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
        if (isCollapsed) {
            sidebar.classList.add('collapsed');
        }

        // йҸҚеӣ©о„·жӨӨйқӣеһҸйҺ№гҲ е§ӣй‘і?        function switchTab(tabName) {
            // з»үе©ҡж«ҺйҺөвӮ¬йҸҲеӨӢжӨҝйҚ”г„§е§ёйҺ¬?            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('active'));
            
            // еЁЈиҜІе§һиӨ°ж’іеў еЁІиҜІе§©йҗҳиҲөвӮ¬?            document.querySelector(`[data-tab="${tabName}"]`).classList.add('active');
            document.getElementById(`tab-${tabName}`).classList.add('active');
        }
    </script>

    <style>
        .archive-list {
            display: flex;
            flex-direction: column;
            gap: var(--spacing-sm);
        }

        .archive-item {
            display: flex;
            align-items: center;
            gap: var(--spacing-md);
            padding: var(--spacing-md);
            background: var(--warm-gray-50);
            border-radius: var(--radius-md);
            transition: all 0.2s ease;
        }

        .archive-item:hover {
            background: var(--warm-gray-100);
        }

        .archive-icon {
            width: 36px;
            height: 36px;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 14px;
            flex-shrink: 0;
        }

        .archive-content {
            flex: 1;
            min-width: 0;
        }

        .archive-title {
            font-size: 14px;
            font-weight: 500;
            color: var(--warm-gray-900);
            margin-bottom: 2px;
        }

        .archive-meta {
            font-size: 12px;
            color: var(--warm-gray-500);
        }

        .archive-badge {
            padding: 4px 10px;
            background: white;
            border-radius: var(--radius-sm);
            font-size: 12px;
            font-weight: 500;
            color: var(--warm-gray-700);
        }
    </style>
    <script src="no-multiline.js"></script>
</body>
</html>


