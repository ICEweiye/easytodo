            color: var(--warm-gray-500);
            line-height: 1.2;
        }

        .finance-trend-value {
            margin-left: 4px;
            font-weight: 600;
            color: var(--warm-gray-700);
        }

        .finance-trend-value.up {
            color: #2f9e44;
        }

        .finance-trend-value.down {
            color: #c92a2a;
        }

        .finance-trend-value.flat {
            color: var(--warm-gray-700);
        }

        .finance-trend-value.na {
            color: var(--warm-gray-400);
        }

        .finance-summary-label {
            color: var(--warm-gray-500);
            font-size: 12px;
            margin-bottom: 2px;
        }

        .finance-summary-value {
            font-size: 20px;
            font-weight: 600;
            color: var(--warm-gray-900);
        }

        .finance-summary-value.income {
            color: #2f9e44;
        }

        .finance-summary-value.investment {
            color: #1c7ed6;
        }

        .finance-summary-value.expense {
            color: #c92a2a;
        }

        .finance-summary-value.balance-positive {
            color: #2f9e44;
        }

        .finance-summary-value.balance-negative {
            color: #c92a2a;
        }

        .finance-chart-wrap {
            border: 0;
            border-radius: 0;
            padding: 0;
            background: transparent;
            overflow-x: hidden;
            max-height: 340px;
            opacity: 1;
            transform-origin: top;
            transition: opacity 0.2s ease;
        }

        .finance-chart {
            min-height: 0;
            height: auto;
            overflow: hidden;
            max-width: 100%;
        }

        .finance-chart-wrap.is-collapsed {
            max-height: 0;
            padding-top: 0;
            padding-bottom: 0;
            border-width: 0;
            opacity: 0;
            pointer-events: none;
        }

        .expense-month-combined {
            height: 220px;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            gap: 8px;
            background: transparent;
            border-radius: 0;
            border: 0;
            padding: 0;
        }

        .expense-month-svg {
            width: 100%;
            height: 186px;
            display: block;
        }

        .expense-month-baseline {
            stroke: var(--warm-gray-200);
            stroke-width: 1;
        }

        .expense-month-grid-line {
            stroke: var(--warm-gray-100);
            stroke-width: 1;
        }

        .expense-month-axis-label {
            fill: var(--warm-gray-500);
            font-size: 10px;
            text-anchor: end;
            dominant-baseline: middle;
        }

        .expense-month-bar {
            fill: rgba(47, 158, 68, 0.4);
        }

        .expense-month-bar.is-positive {
            fill: rgba(47, 158, 68, 0.45);
        }

        .expense-month-bar.is-negative {
            fill: rgba(201, 42, 42, 0.4);
        }

        .expense-month-area {
            fill: none;
        }

        .expense-month-line {
            fill: none;
            stroke-width: 1.6;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .expense-month-line.is-expense {
            stroke: #c92a2a;
        }

        .expense-month-line.is-income {
            stroke: #2f9e44;
        }

        .expense-month-line.is-investment {
            stroke: #1c7ed6;
        }

        .expense-month-point.is-expense {
            fill: #c92a2a;
        }

        .expense-month-point.is-income {
            fill: #2f9e44;
        }

        .expense-month-point.is-investment {
            fill: #1c7ed6;
        }

        .finance-month-legend {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 30px;
            align-items: center;
            min-height: 18px;
        }

        .finance-month-legend-item {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--warm-gray-600);
        }

        .finance-month-legend-dot {
            width: 8px;
            height: 8px;
            border-radius: 999px;
            display: inline-block;
        }

        .finance-month-legend-dot.is-expense {
            background: #c92a2a;
        }

        .finance-month-legend-dot.is-income {
            background: #2f9e44;
        }

        .finance-month-legend-dot.is-investment {
            background: #1c7ed6;
        }

        .expense-month-labels {
            display: grid;
            gap: 0;
            width: 100%;
            box-sizing: border-box;
            margin-top: -18px;
        }

        .expense-month-label {
            text-align: center;
            font-size: 11px;
            color: var(--warm-gray-500);
            line-height: 1;
        }

        .finance-empty {
            color: var(--warm-gray-500);
            font-size: 13px;
            margin-top: 8px;
            min-height: 20px;
        }

        .finance-empty.is-invisible {
            visibility: hidden;
        }

        @media (max-width: 768px) {
            .finance-summary {
                grid-template-columns: 1fr;
            }

            .finance-summary-item {
                flex-direction: column;
                align-items: center;
            }

            .finance-summary-left {
                width: 100%;
                justify-content: center;
            }

            .finance-trends {
                margin-left: 0;
                align-items: center;
            }

            .expense-entry-row {
                grid-template-columns: 1fr;
            }

            .reconcile-entry-row {
                grid-template-columns: 1fr;
            }

            .expense-entry-row .form-input {
                max-width: 100%;
            }

            .expense-entry-row .btn,
            .reconcile-entry-row .btn {
                width: 100%;
            }
        }
    </style>
    <script src="no-multiline.js"></script>
</body>
</html>


