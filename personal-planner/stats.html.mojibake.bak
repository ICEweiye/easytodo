        #weeklyExpenseInput::-webkit-outer-spin-button,
        #weeklyExpenseInput::-webkit-inner-spin-button,
        #weeklyIncomeInput::-webkit-outer-spin-button,
        #weeklyIncomeInput::-webkit-inner-spin-button,
